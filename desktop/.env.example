# =========================================================
# Dilara AI Assistant — Masaüstü Konfigürasyonu
# =========================================================
# Bu dosyayı .env olarak kopyala ve anahtarlarını doldur.
# Hiçbir anahtarı git'e commitleme.

# ----- Kullanıcı bilgileri -----
DILARA_USER_NAME=İbo
DILARA_USER_LANGUAGE=tr

# ----- LLM sağlayıcısı seçimi -----
# Geçerli değerler: openai | anthropic | gemini
DILARA_LLM_PROVIDER=openai
DILARA_LLM_MODEL=gpt-4o
DILARA_LLM_FALLBACK_PROVIDER=anthropic
DILARA_LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022

# ----- API anahtarları -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ----- TTS -----
# Geçerli değerler: elevenlabs | openai | edge
DILARA_TTS_PROVIDER=edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Edge-TTS için Türkçe kadın sesleri:
#   tr-TR-EmelNeural (kadın), tr-TR-AhmetNeural (erkek)
DILARA_TTS_VOICE=tr-TR-EmelNeural
DILARA_TTS_RATE=+5%
DILARA_TTS_PITCH=+0Hz

# ----- STT -----
# Geçerli değerler: whisper-api | faster-whisper
DILARA_STT_PROVIDER=faster-whisper
DILARA_STT_MODEL=base
DILARA_STT_LANGUAGE=tr

# ----- Wake Word -----
DILARA_WAKE_WORD=hey_dilara
DILARA_WAKE_THRESHOLD=0.5
DILARA_WAKE_ENABLED=true

# ----- Backend (opsiyonel sync için) -----
DILARA_BACKEND_URL=http://localhost:8000
DILARA_BACKEND_TOKEN=
DILARA_SYNC_ENABLED=false

# ----- Güvenlik -----
# Hafıza şifrelemesi için. İlk çalıştırmada otomatik üretilir.
DILARA_ENCRYPTION_KEY=

# ----- Davranış -----
DILARA_DEFAULT_MODE=normal
DILARA_LOG_LEVEL=INFO
